# ===================================
# 公众号文章自动生成系统 - 环境变量配置
# ===================================
# 使用说明：复制此文件为 .env 并填写实际值

# -----------------------------------
# AI 平台配置
# -----------------------------------

# 通义千问 API 配置（推荐）
DASHSCOPE_API_KEY=your_api_key_here

# OpenAI API 配置（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek API 配置（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 AI 配置（可选）
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# -----------------------------------
# 微信公众号配置（可选 - 需要已认证的服务号）
# -----------------------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=

# -----------------------------------
# 邮件通知配置（可选）
# -----------------------------------
SMTP_SERVER=
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=
RECIPIENT_EMAILS=

# -----------------------------------
# 服务配置
# -----------------------------------
HOST=0.0.0.0
PORT=8601

# Streamlit 配置
STREAMLIT_SERVER_PORT=8601
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# -----------------------------------
# Docker 配置（可选）
# -----------------------------------
# 资源限制
CPU_LIMIT=2.0
MEMORY_LIMIT=2G
